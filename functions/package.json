{
  "name": "cliff-recruiter-functions",
  "description": "Cloud Functions: signup OTP + Ceipal report proxy + LLM resume parsing",
  "type": "module",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
