# ---------------------------------------------------------------------------
# Cloud Functions configuration.
# Copy to "functions/.env" for local emulator runs. For deployed functions,
# set the SECRET values with:  firebase functions:secrets:set NAME
# (see README.md). Never commit the real .env file.
# ---------------------------------------------------------------------------

# --- Ceipal (non-secret identifiers; safe as env) ---
CEIPAL_EMAIL=abhishek.g@cliff-services.com
CEIPAL_API_KEY=PLACEHOLDER_CEIPAL_API_KEY
CEIPAL_AUTH_URL=https://api.ceipal.com/v2/createAuthtoken/

# Report endpoints (from the API documentation). Change only if Ceipal reissues them.
CEIPAL_JOB_DURATION_URL=https://atsbi.ceipal.com/api/report-details/get-report-data/4ZxpwPJG8sLgShkgAHOI9kdUWgQtpquLtSQ_cCu5u2g?response_type=1
CEIPAL_SUBMISSIONS_URL=https://atsbi.ceipal.com/api/report-details/get-report-data/0_NbuPU5KbRzHtd6lrlnIR3w2uHRuz_sCkm0EWi1T_s?response_type=1
# Recruiter activity reports (job-board credits, pipeline update logs, mail merge).
CEIPAL_JOB_BOARD_URL=https://atsbi.ceipal.com/api/report-details/get-report-data/zvBJhK61mYMidnny3v8AGTay16WUyY6orM-tu21m4ac?response_type=1
CEIPAL_PIPELINE_LOGS_URL=https://atsbi.ceipal.com/api/report-details/get-report-data/ia7wkPzresBPyenrkFj3wfqDmGQVuTghkkIzmz7dcZs?response_type=1
CEIPAL_MAIL_MERGE_URL=https://atsbi.ceipal.com/api/report-details/get-report-data/ALM6EEgbFv8KELyZj53j0m1TnyAPjLbySHS9CpkC8ko?response_type=1
CEIPAL_ADV_SEARCH_URL=https://atsbi.ceipal.com/api/report-details/get-report-data/wUgs1j8iTTE1XqgmEbuOarqM5Vl-Hvrf-p1n-OJDC-w?response_type=1
CEIPAL_ACTIVE_JOBS_URL=https://atsbi.ceipal.com/api/report-details/get-report-data/btKb7FaSUafLjgnzA4SlUmz4nFTSpUgHulM34SUbJ7E?response_type=1

# Optional: a monthly LLM budget in USD. When set, the Resume Parsing page shows
# a running "balance" (budget − estimated spend). Leave unset to hide the balance.
# LLM_BUDGET_USD=50

# --- LLM (Ollama, OpenAI-compatible) ---
# Ollama Cloud: https://ollama.com/v1  (uses the LLM_API_KEY secret below)
# Local Ollama: http://localhost:11434/v1  (no key needed; not reachable from
#   deployed Cloud Functions — only for local emulator runs)
LLM_BASE_URL=https://ollama.com/v1
# Model must be one available on your Ollama account, e.g. gpt-oss:20b,
# deepseek-v3.2, gemma3:27b, qwen3-coder:480b, etc.
LLM_MODEL=gpt-oss:20b

# --- Signup / OTP ---
# Only this email domain may register. Leave as-is for Cliff Services.
ALLOWED_EMAIL_DOMAIN=cliff-services.com
# SMTP for sending the OTP email (non-secret parts). Use your Google Workspace
# SMTP, SendGrid, Mailgun, etc. The password goes in the SMTP_PASS secret.
SMTP_HOST=PLACEHOLDER_SMTP_HOST
SMTP_PORT=587
SMTP_USER=PLACEHOLDER_SMTP_USER
SMTP_FROM=Cliff Recruiter Suite <no-reply@cliff-services.com>
# Local testing only: when true and SMTP is not set, the OTP is returned in the
# API response instead of emailed. NEVER enable in production.
OTP_DEV_MODE=false

# ---------------------------------------------------------------------------
# SECRETS — do NOT put real values here for production. Use functions:secrets:set.
# Provided here only so the local emulator can run.
# ---------------------------------------------------------------------------
CEIPAL_PASSWORD=PLACEHOLDER_CEIPAL_PASSWORD
# Ollama Cloud API key (from https://ollama.com — Settings → API keys)
LLM_API_KEY=PLACEHOLDER_OLLAMA_API_KEY
# OpenAI API key (optional second provider; leave placeholder to keep it greyed out)
OPENAI_API_KEY=PLACEHOLDER_OPENAI_API_KEY
SMTP_PASS=PLACEHOLDER_SMTP_PASS
