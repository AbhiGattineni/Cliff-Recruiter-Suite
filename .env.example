# ---------------------------------------------------------------------------
# FRONTEND (Vite) environment variables.
# Copy this file to ".env" and fill in your real Firebase web-app config.
# Vite only exposes variables prefixed with VITE_ to the browser.
# These Firebase web values are NOT secret (they identify the project);
# real secrets (Ceipal password, LLM token) live in Cloud Functions only.
# ---------------------------------------------------------------------------

VITE_FIREBASE_API_KEY=PLACEHOLDER_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=PLACEHOLDER_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=PLACEHOLDER_PROJECT
VITE_FIREBASE_STORAGE_BUCKET=PLACEHOLDER_PROJECT.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=PLACEHOLDER_SENDER_ID
VITE_FIREBASE_APP_ID=PLACEHOLDER_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=PLACEHOLDER_MEASUREMENT_ID

# Region where the Cloud Functions are deployed (default: us-central1)
VITE_FUNCTIONS_REGION=us-central1

# Set to "true" to point the app at local Firebase emulators during development
VITE_USE_EMULATORS=false
